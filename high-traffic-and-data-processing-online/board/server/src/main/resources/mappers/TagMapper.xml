<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="pcy.study.server.mapper.TagMapper">

    <insert id="insertTag" useGeneratedKeys="true" keyProperty="id"
            parameterType="pcy.study.server.domain.Tag">
    <![CDATA[
        INSERT INTO tag ( name
                        , url)
        VALUES ( #{name}
               , #{url})
    ]]>
    </insert>

    <insert id="insertPostTags" parameterType="pcy.study.server.domain.Post">
    <![CDATA[
        INSERT INTO postTag ( postId
                            , tagId)
        VALUES
    ]]>
        <foreach collection="postTags" item="postTag" separator=",">
        <![CDATA[
             ( #{id}
             , #{postTag.tagId})
        ]]>
        </foreach>
    </insert>

    <select id="findById" resultType="pcy.study.server.domain.Tag">
    <![CDATA[
        SELECT id
             , name
             , url
        FROM tag
        WHERE id = #{id}
    ]]>
    </select>

    <update id="updateTag" parameterType="pcy.study.server.domain.Tag">
    <![CDATA[
        UPDATE tag
        SET name = #{name}
          , url = #{url}
        WHERE id = #{id}
    ]]>
    </update>

    <delete id="deleteTag">
    <![CDATA[
        DELETE
        FROM tag
        WHERE id = #{id}
    ]]>
    </delete>

    <delete id="deletePostTagByPostId">
    <![CDATA[
        DELETE
        FROM postTag
        WHERE postId = #{postId}
        ]]>
    </delete>

</mapper>
